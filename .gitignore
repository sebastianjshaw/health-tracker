# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local SQLite database
local.db
*.db
*.db-journal
*.db-wal
*.db-shm

# personal health scans / PII / private docs — keep the whole folder out of git
docs/

# OAuth / API credentials & tokens (Google Health, etc.) — never commit
credentials.json
client_secret*.json
*-credentials.json
token.json
*.token.json
service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.env.local
.env.example